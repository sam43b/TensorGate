# Llama CPP Management - Environment Configuration
# These values externalize hardcoded paths and ports from app.py

# Project base directory (used as PROJECT_DIR)
PROJECT_DIR=~/llama

# Model directories
MODEL_DIR=/media/user/HDD_2To/llm
EMBEDDING_MODEL_DIR=/media/user/HDD_2To/EMBEDDING
RERANKER_MODEL_DIR=/media/user/HDD_2To/RERANKER

# llama.cpp server executable path
LLAMA_CPP_PATH=/home/user/appz/llama_cpp/build/bin/llama-server

# Cache directory
CACHE_DIR=~/.cache/llama

# Custom apps configuration (relative to app.py location)
CUSTOM_APPS_ENV_FILE=custom_apps.cfg
PRESETS_FILE=presets.cfg

# Default ports
LLM_DEFAULT_PORT=8080
EMBEDDING_DEFAULT_PORT=8081
RERANKER_DEFAULT_PORT=8082
FLASK_APP_PORT=5000

#LLama.cpp Default Flags
LLM_DEFAULT_Flags=--batch-size 2048 --ubatch-size 512 --cache-reuse 256 --mlock --no-mmap --jinja -cram -1 --threads-http 2 --reasoning-budget 0 --fit on

#MTP
LLM_DEFAULT_MTP=--spec-type draft-mtp --spec-draft-n-max 3
